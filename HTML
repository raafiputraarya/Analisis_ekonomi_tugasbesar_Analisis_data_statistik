    <script>
        AOS.init({ once: false, offset: 60, easing: 'ease-out-cubic' });

        /* PARTICLE BG */
        const canvas = document.getElementById('hero-canvas');
        const ctx = canvas.getContext('2d');

        function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight }
        resize();
        window.addEventListener('resize', () => { resize(); init() });

        const COLS = ['#FF6B2B', '#FFB830', '#00C896', '#00B4D8', '#7B5EA7', '#FF4D8D'];
        let pts = [];

        function rand(a, b) { return Math.random() * (b - a) + a }

        function init() {
            pts = [];
            const N = Math.floor(canvas.width * canvas.height / 7500);
            for (let i = 0; i < N; i++) pts.push({
                x: rand(0, canvas.width), y: rand(0, canvas.height),
                r: rand(.8, 3), vx: rand(-.3, .3), vy: rand(-.2, .2),
                color: COLS[Math.floor(Math.random() * COLS.length)],
                alpha: rand(.15, .5), ph: rand(0, Math.PI * 2), ps: rand(.01, .025)
            });
        }
        init();

        function hex2rgb(h) { const r = parseInt(h.slice(1, 3), 16), g = parseInt(h.slice(3, 5), 16), b = parseInt(h.slice(5, 7), 16); return `${r},${g},${b}` }

        function tick() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (let i = 0; i < pts.length; i++) {
                for (let j = i + 1; j < pts.length; j++) {
                    const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y, d = Math.hypot(dx, dy);
                    if (d < 120) {
                        ctx.beginPath();
                        ctx.strokeStyle = `rgba(255,255,255,${(1 - d / 120) * .08})`;
                        ctx.lineWidth = .5;
                        ctx.moveTo(pts[i].x, pts[i].y);
                        ctx.lineTo(pts[j].x, pts[j].y);
                        ctx.stroke();
                    }
                }
            }

            pts.forEach(p => {
                p.ph += p.ps;
                const a = p.alpha + Math.sin(p.ph) * .1;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(${hex2rgb(p.color)},${a})`;
                ctx.fill();
                p.x += p.vx; p.y += p.vy;
                if (p.x < -10) p.x = canvas.width + 10;
                if (p.x > canvas.width + 10) p.x = -10;
                if (p.y < -10) p.y = canvas.height + 10;
                if (p.y > canvas.height + 10) p.y = -10;
            });

            requestAnimationFrame(tick);
        }
        tick();
    </script>
